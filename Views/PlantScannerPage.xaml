<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="bashta_mobile.Views.PlantScannerPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Plant Scanner">

	<ScrollView>
		<VerticalStackLayout Padding="24" Spacing="18">

			<Label
                Text="Plant Scanner"
                Style="{StaticResource PageTitleLabelStyle}"
                SemanticProperties.HeadingLevel="Level1" />

			<Label
                Text="{Binding StatusMessage}"
                Style="{StaticResource BodyLabelStyle}" />

			<Border
                IsVisible="{Binding ErrorMessage, Converter={StaticResource StringNotNullOrEmptyConverter}}"
                Style="{StaticResource CardBorderStyle}">
				<Label
                    Text="{Binding ErrorMessage}"
                    TextColor="{StaticResource ErrorColor}"
                    Style="{StaticResource BodyLabelStyle}" />
			</Border>

			<Border Style="{StaticResource CardBorderStyle}">
				<VerticalStackLayout Spacing="12">

					<Label
                        Text="Odabir biljke"
                        Style="{StaticResource SectionTitleLabelStyle}" />

					<Label
                        Text="Saksija"
                        Style="{StaticResource BodyLabelStyle}" />

					<Picker
                        ItemsSource="{Binding Pots}"
                        SelectedItem="{Binding SelectedPot}"
                        ItemDisplayBinding="{Binding DisplayName}"
                        Title="Odaberi saksiju"
                        SemanticProperties.Description="Odabir saksije za analizu biljke" />

					<Label
                        Text="Aktivna biljka"
                        Style="{StaticResource BodyLabelStyle}" />

					<Label
                        Text="{Binding SelectedPlantName}"
                        FontSize="18"
                        FontAttributes="Bold"
                        TextColor="{StaticResource EmeraldGreen}" />

				</VerticalStackLayout>
			</Border>

			<Border Style="{StaticResource CardBorderStyle}">
				<VerticalStackLayout Spacing="14">

					<Label
                        Text="Fotografija lista"
                        Style="{StaticResource SectionTitleLabelStyle}" />

					<Button
                        Text="Odaberi fotografiju"
                        Command="{Binding PickImageCommand}"
                        Style="{StaticResource SecondaryButtonStyle}"
                        SemanticProperties.Description="Odaberi fotografiju lista za analizu" />

					<Image
                        Source="{Binding PreviewImage}"
                        HeightRequest="240"
                        Aspect="AspectFit"
                        BackgroundColor="{StaticResource CreasedKhaki}" />

					<Button
                        Text="Analiziraj"
                        Command="{Binding AnalyzeCommand}"
                        Style="{StaticResource PrimaryButtonStyle}"
                        SemanticProperties.Description="Pokreni ML analizu zdravlja biljke" />

					<ActivityIndicator
                        IsRunning="{Binding IsBusy}"
                        IsVisible="{Binding IsBusy}" />

				</VerticalStackLayout>
			</Border>

			<Border
                IsVisible="{Binding HasResult}"
                Style="{StaticResource CardBorderStyle}">
				<VerticalStackLayout Spacing="10">

					<Label
                        Text="Rezultat analize"
                        Style="{StaticResource SectionTitleLabelStyle}" />

					<Label
                        Text="{Binding ResultTitle}"
                        FontSize="18"
                        FontAttributes="Bold"
                        TextColor="{StaticResource EmeraldGreen}" />

					<Label
                        Text="{Binding ResultConfidence}"
                        Style="{StaticResource BodyLabelStyle}" />

					<Label
                        Text="{Binding ResultRecommendation}"
                        Style="{StaticResource BodyLabelStyle}" />

				</VerticalStackLayout>
			</Border>

		</VerticalStackLayout>
	</ScrollView>
</ContentPage>