<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="bashta_mobile.Views.MyPotsPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Moje saksije">

    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="18">

            <Label
                Text="Moje saksije"
                Style="{StaticResource PageTitleLabelStyle}"
                SemanticProperties.HeadingLevel="Level1" />

            <Label
                Text="{Binding SummaryText}"
                Style="{StaticResource BodyLabelStyle}" />

            <ActivityIndicator
                IsRunning="{Binding IsBusy}"
                IsVisible="{Binding IsBusy}" />

            <Border
                IsVisible="{Binding ErrorMessage, Converter={StaticResource StringNotNullOrEmptyConverter}}"
                Style="{StaticResource CardBorderStyle}">
                <Label
                    Text="{Binding ErrorMessage}"
                    TextColor="{StaticResource ErrorColor}"
                    Style="{StaticResource BodyLabelStyle}" />
            </Border>

            <CollectionView
                x:Name="PotsCollectionView"
                ItemsSource="{Binding Pots}"
                SelectionMode="None">

                <CollectionView.EmptyView>
                    <Border Style="{StaticResource CardBorderStyle}">
                        <VerticalStackLayout Spacing="8">
                            <Label
                                Text="Nema dodanih saksija"
                                Style="{StaticResource SectionTitleLabelStyle}" />

                            <Label
                                Text="Dodavanje novih saksija predviđeno je kao dio skalabilnosti sistema."
                                Style="{StaticResource BodyLabelStyle}" />
                        </VerticalStackLayout>
                    </Border>
                </CollectionView.EmptyView>

                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource CardBorderStyle}">

                            <Border.GestureRecognizers>
                                <TapGestureRecognizer
                                    Command="{Binding Source={x:Reference PotsCollectionView}, Path=BindingContext.OpenDetailsCommand}"
                                    CommandParameter="{Binding .}" />
                            </Border.GestureRecognizers>

                            <VerticalStackLayout Spacing="10">

                                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                    <Label
                                        Grid.Column="0"
                                        Text="{Binding Name}"
                                        FontSize="20"
                                        FontAttributes="Bold"
                                        TextColor="{StaticResource TextPrimaryColor}"
                                        LineBreakMode="TailTruncation" />

                                    <VerticalStackLayout
                                        Grid.Column="1"
                                        HorizontalOptions="End"
                                        Spacing="2">

                                        <Label
                                            Text="{Binding HealthBadgeText}"
                                            FontSize="13"
                                            FontAttributes="Bold"
                                            TextColor="{Binding HealthBadgeColor}"
                                            HorizontalTextAlignment="End" />

                                        <Label
                                            Text="{Binding StatusText}"
                                            FontSize="11"
                                            TextColor="{StaticResource TextSecondaryColor}"
                                            HorizontalTextAlignment="End" />
                                    </VerticalStackLayout>
                                </Grid>

                                <Label
                                    Text="{Binding PlantName}"
                                    FontSize="16"
                                    FontAttributes="Bold"
                                    TextColor="{StaticResource TextSecondaryColor}" />

                                <Grid
                                    ColumnDefinitions="Auto,*"
                                    RowDefinitions="Auto,Auto,Auto,Auto"
                                    ColumnSpacing="10"
                                    RowSpacing="8">

                                    <Label
                                        Grid.Row="0"
                                        Grid.Column="0"
                                        Text="Tip:"
                                        FontAttributes="Bold"
                                        TextColor="{StaticResource TextPrimaryColor}" />

                                    <Label
                                        Grid.Row="0"
                                        Grid.Column="1"
                                        Text="{Binding PlantTypeName}"
                                        Style="{StaticResource BodyLabelStyle}" />

                                    <Label
                                        Grid.Row="1"
                                        Grid.Column="0"
                                        Text="Lokacija:"
                                        FontAttributes="Bold"
                                        TextColor="{StaticResource TextPrimaryColor}" />

                                    <Label
                                        Grid.Row="1"
                                        Grid.Column="1"
                                        Text="{Binding Location}"
                                        Style="{StaticResource BodyLabelStyle}" />

                                    <Label
                                        Grid.Row="2"
                                        Grid.Column="0"
                                        Text="Bolest:"
                                        FontAttributes="Bold"
                                        TextColor="{StaticResource TextPrimaryColor}" />

                                    <VerticalStackLayout
                                        Grid.Row="2"
                                        Grid.Column="1"
                                        Spacing="2">

                                        <Label
                                            Text="{Binding LatestDiseaseText}"
                                            Style="{StaticResource BodyLabelStyle}" />

                                        <Label
                                            Text="{Binding LatestDiseaseDateText}"
                                            IsVisible="{Binding LatestDiseaseDateText, Converter={StaticResource StringNotNullOrEmptyConverter}}"
                                            FontSize="12"
                                            TextColor="{StaticResource TextSecondaryColor}" />
                                    </VerticalStackLayout>

                                    <Label
                                        Grid.Row="3"
                                        Grid.Column="0"
                                        Text="Datum:"
                                        FontAttributes="Bold"
                                        TextColor="{StaticResource TextPrimaryColor}" />

                                    <Label
                                        Grid.Row="3"
                                        Grid.Column="1"
                                        Text="{Binding CreatedAtText}"
                                        Style="{StaticResource BodyLabelStyle}" />

                                </Grid>

                                <Label
                                    Text="Dodirni karticu za detaljni prikaz biljke."
                                    FontSize="12"
                                    TextColor="{StaticResource TextSecondaryColor}" />

                                <Grid
                                    ColumnDefinitions="*,*"
                                    ColumnSpacing="12"
                                    Margin="0,8,0,0">

                                    <Button
                                        Grid.Column="0"
                                        Text="Uredi"
                                        Command="{Binding Source={x:Reference PotsCollectionView}, Path=BindingContext.EditPotCommand}"
                                        CommandParameter="{Binding .}"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        SemanticProperties.Description="Uredi podatke o saksiji" />

                                    <Button
                                        Grid.Column="1"
                                        Text="Obriši"
                                        Command="{Binding Source={x:Reference PotsCollectionView}, Path=BindingContext.DeletePotCommand}"
                                        CommandParameter="{Binding .}"
                                        BackgroundColor="{StaticResource EgyptianEarth}"
                                        TextColor="{StaticResource TextOnDarkColor}"
                                        CornerRadius="18"
                                        HeightRequest="52"
                                        FontAttributes="Bold"
                                        SemanticProperties.Description="Obriši saksiju" />
                                </Grid>

                            </VerticalStackLayout>

                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <Button
                Text="Dodaj novu saksiju"
                Command="{Binding AddPotCommand}"
                Style="{StaticResource SecondaryButtonStyle}"
                SemanticProperties.Description="Dodaj novu pametnu saksiju"
                SemanticProperties.Hint="Otvara formu za dodavanje nove saksije" />

            <Button
                Text="Osvježi listu"
                Command="{Binding LoadCommand}"
                Style="{StaticResource PrimaryButtonStyle}"
                SemanticProperties.Description="Osvježi listu saksija"
                SemanticProperties.Hint="Ponovo učitava saksije povezane s korisnikom" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>