<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="bashta_mobile.Views.EditPotPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Uredi saksiju">

    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="18">

            <Label
                Text="Uredi saksiju"
                Style="{StaticResource PageTitleLabelStyle}"
                SemanticProperties.HeadingLevel="Level1" />

            <Label
                Text="{Binding StatusMessage}"
                Style="{StaticResource BodyLabelStyle}" />

            <Border
                IsVisible="{Binding ErrorMessage, Converter={StaticResource StringNotNullOrEmptyConverter}}"
                Style="{StaticResource CardBorderStyle}">
                <Label
                    Text="{Binding ErrorMessage}"
                    TextColor="{StaticResource ErrorColor}"
                    Style="{StaticResource BodyLabelStyle}" />
            </Border>

            <Border Style="{StaticResource CardBorderStyle}">
                <VerticalStackLayout Spacing="14">

                    <Label
                        Text="Podaci o saksiji"
                        Style="{StaticResource SectionTitleLabelStyle}" />

                    <Label Text="Naziv saksije" Style="{StaticResource BodyLabelStyle}" />

                    <Entry
                        Text="{Binding Name}"
                        Placeholder="npr. Balkonski paradajz"
                        ClearButtonVisibility="WhileEditing"
                        SemanticProperties.Description="Naziv pametne saksije" />

                    <Label Text="Lokacija" Style="{StaticResource BodyLabelStyle}" />

                    <Entry
                        Text="{Binding Location}"
                        Placeholder="npr. Balkon, jug"
                        ClearButtonVisibility="WhileEditing"
                        SemanticProperties.Description="Lokacija saksije" />

                    <Label Text="MAC adresa uređaja" Style="{StaticResource BodyLabelStyle}" />

                    <Entry
                        Text="{Binding MacAddress}"
                        Placeholder="npr. AA:BB:CC:DD:EE:FF"
                        ClearButtonVisibility="WhileEditing"
                        Keyboard="Text"
                        SemanticProperties.Description="MAC adresa IoT uređaja" />

                    <Label Text="Firmware verzija" Style="{StaticResource BodyLabelStyle}" />

                    <Entry
                        Text="{Binding FirmwareVersion}"
                        Placeholder="npr. 1.0.0"
                        ClearButtonVisibility="WhileEditing"
                        Keyboard="Text"
                        SemanticProperties.Description="Firmware verzija pametne saksije" />
                    <Label
                        Text="Posađena biljka"
                        Style="{StaticResource BodyLabelStyle}" />

                                        <Picker
                        ItemsSource="{Binding PlantTypes}"
                        SelectedItem="{Binding SelectedPlantType}"
                        ItemDisplayBinding="{Binding DisplayName}"
                        Title="Odaberi biljku"
                        SemanticProperties.Description="Odabir posađene biljke iz baze dostupnih biljaka" />

                                        <Label
                        Text="Nadimak biljke"
                        Style="{StaticResource BodyLabelStyle}" />

                                        <Entry
                        Text="{Binding PlantNickname}"
                        Placeholder="npr. Cherry paradajz"
                        ClearButtonVisibility="WhileEditing"
                        SemanticProperties.Description="Nadimak biljke u saksiji" />
                </VerticalStackLayout>
            </Border>

            <ActivityIndicator
                IsRunning="{Binding IsBusy}"
                IsVisible="{Binding IsBusy}" />

            <Button
                Text="Sačuvaj promjene"
                Command="{Binding SaveCommand}"
                Style="{StaticResource PrimaryButtonStyle}"
                SemanticProperties.Description="Sačuvaj izmjene pametne saksije" />

            <Button
                Text="Odustani"
                Command="{Binding CancelCommand}"
                Style="{StaticResource SecondaryButtonStyle}"
                SemanticProperties.Description="Odustani od uređivanja saksije" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>